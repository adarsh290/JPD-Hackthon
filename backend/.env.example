# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smartlinkhub?schema=public"

# JWT Configuration (MUST be at least 32 characters in production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-must-be-32-chars-minimum"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL for CORS (must be a valid URL)
FRONTEND_URL="http://localhost:5173"
