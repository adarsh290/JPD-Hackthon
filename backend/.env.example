# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smartlinkhub?schema=public"

# JWT Configuration (MUST be at least 32 characters in production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-must-be-32-chars"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:8081"

# Production Example:
# DATABASE_URL="postgresql://username:password@hostname:port/database"
# JWT_SECRET="production-jwt-secret-32-characters-minimum-length"
# FRONTEND_URL="https://your-frontend-domain.com"
# NODE_ENV="production"
# PORT="10000"
